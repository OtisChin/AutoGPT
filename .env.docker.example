# Public URLs used by browsers.
# If you expose frontend/backend directly by IP:
# FRONTEND_ORIGIN=http://your-server-ip:3001
# NEXT_PUBLIC_BACKEND_API_BASE_URL=http://your-server-ip:4000
#
# If you use HTTPS domains:
# FRONTEND_ORIGIN=https://redeem.example.com
# NEXT_PUBLIC_BACKEND_API_BASE_URL=https://api.redeem.example.com

FRONTEND_ORIGIN=http://localhost:3001
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_UPSTREAM_API_BASE_URL=https://cha.nerver.cc

FRONTEND_PORT=3001
BACKEND_PORT=4000

ADMIN_TOKEN=replace-with-a-long-random-admin-token
ICE_UPI_BASE_URL=https://upi.iceaix.com
ICE_UPI_ACCESS_TOKEN=replace-with-your-ice-token

SESSION_COOKIE_NAME=autogpt_session
SESSION_TTL_DAYS=30
SECURE_COOKIES=false

POLL_INTERVAL_MS=2500
MAX_CONCURRENT_UPSTREAM=3
